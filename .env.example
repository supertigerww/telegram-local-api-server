# Required Telegram API credentials.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# These image flags are enabled when the variable is present.
# Leave them set for the default local-mode/statistics behavior in this repo.
TELEGRAM_LOCAL=1
TELEGRAM_STAT=1
TELEGRAM_MAX_WEBHOOK_CONNECTIONS=100
# Main Bot API listener. Other containers on telegram-shared can use
# http://telegram-bot-api:8081 by default. Port 8082 is only for the
# internal stats/healthcheck endpoint.
TELEGRAM_HTTP_PORT=8081

# Optional host-side paths used by docker-compose.yml
TELEGRAM_DATA_DIR=./data
TELEGRAM_FILES_DIR=./files
